FROM rust:1-bookworm AS builder
WORKDIR /app
COPY Cargo.toml Cargo.toml
COPY src src
RUN cargo build --release

FROM debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /app/target/release/archivekong-relay-service /usr/local/bin/archivekong-relay-service
ENV ARCHIVEKONG_RELAY_BIND=0.0.0.0:8080
ENV ARCHIVEKONG_RELAY_DATABASE=/data/relay.sqlite
EXPOSE 8080
CMD ["archivekong-relay-service"]
